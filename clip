#!/usr/bin/env bash
#
# clip - リモート側から Windows の clipd を叩いてクリップボード内容を取得する
#
# 使い方:
#   clip          クリップボードの中身を自動判別して出す
#   clip -d DIR   画像の保存先 (既定: mktemp で生成した /tmp 以下)
#   clip -q       パスや本文だけを出力 (Claude Code に渡しやすい)
#
# 事前設定:
#   export CLIPD_HOST=my-windows     # Tailscale の MagicDNS 名 or 100.x.y.z
#   export CLIPD_PORT=9999           # 任意 (既定 9999)
#   export CLIPD_TOKEN=secret        # clipd を -Token 付きで起動した場合のみ
#
# 仕組み:
#   同じ tailnet 上の Windows で動く clipd に GET /clip する。
#   X-Clip-Kind ヘッダ (image|files|text|empty) で分岐する。

set -euo pipefail

CLIPD_HOST="${CLIPD_HOST:-}"
CLIPD_PORT="${CLIPD_PORT:-9999}"
CLIPD_TOKEN="${CLIPD_TOKEN:-}"
SAVE_DIR=""
QUIET=0

usage() {
    sed -n '2,18p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
}

while getopts "d:qh" opt; do
    case "$opt" in
        d) SAVE_DIR="$OPTARG" ;;
        q) QUIET=1 ;;
        h) usage ;;
        *) usage ;;
    esac
done

if [[ -z "$CLIPD_HOST" ]]; then
    echo "error: CLIPD_HOST is not set. e.g. export CLIPD_HOST=my-windows" >&2
    exit 1
fi

BASE="http://${CLIPD_HOST}:${CLIPD_PORT}"
URL="$BASE/clip"

CURL_ARGS=(-fsS -D - --max-time 10)
if [[ -n "$CLIPD_TOKEN" ]]; then
    CURL_ARGS+=(-H "Authorization: Bearer $CLIPD_TOKEN")
fi

TMP_BODY="$(mktemp)"
trap 'rm -f "$TMP_BODY"' EXIT

if ! HDRS="$(curl "${CURL_ARGS[@]}" -o "$TMP_BODY" "$URL" 2>/dev/null)"; then
    code="$(curl -s -o /dev/null -w '%{http_code}' "${CURL_ARGS[@]:1}" "$URL" 2>/dev/null || true)"
    case "$code" in
        401) echo "error: unauthorized (CLIPD_TOKEN を確認)" >&2 ;;
        404) echo "error: not found ($URL)" >&2 ;;
        000|"") echo "error: cannot reach clipd at $BASE (tailnet 接続と clipd 起動を確認)" >&2 ;;
        *)   echo "error: clipd returned HTTP $code" >&2 ;;
    esac
    exit 1
fi

KIND="$(printf '%s' "$HDRS" | tr -d '\r' | awk -F': ' 'tolower($1)=="x-clip-kind"{print $2}')"

case "$KIND" in
    image)
        if [[ -n "$SAVE_DIR" ]]; then
            mkdir -p "$SAVE_DIR"
            DEST="$SAVE_DIR/clip_$(date +%Y%m%d_%H%M%S).png"
        else
            DEST="$(mktemp --suffix=.png)"
        fi
        cp "$TMP_BODY" "$DEST"
        if [[ "$QUIET" -eq 1 ]]; then printf '%s\n' "$DEST"
        else echo "画像を保存しました: $DEST"; fi
        ;;
    text)
        cat "$TMP_BODY"
        [[ "$QUIET" -eq 1 ]] || echo
        ;;
    files)
        # パスを JSON 配列から取り出す
        if command -v jq &>/dev/null; then
            mapfile -t _paths < <(jq -r '.[]' < "$TMP_BODY")
        else
            mapfile -t _paths < <(python3 -c "
import json,sys
for p in json.load(sys.stdin): print(p)" < "$TMP_BODY")
        fi

        if [[ "${#_paths[@]}" -eq 0 ]]; then
            [[ "$QUIET" -eq 1 ]] || echo "クリップボードにファイルがありません。"
        else
            # トークンヘッダ部 (コマンド文字列に埋め込む)
            _auth_flag=""
            [[ -n "$CLIPD_TOKEN" ]] && _auth_flag="-H 'Authorization: Bearer ${CLIPD_TOKEN}' "

            [[ "$QUIET" -eq 1 ]] || echo "クリップボード: ファイル ${#_paths[@]}件"
            [[ "$QUIET" -eq 1 ]] || echo

            for _winpath in "${_paths[@]}"; do
                # Windows パスを URL エンコード
                if command -v jq &>/dev/null; then
                    _enc=$(jq -rn --arg p "$_winpath" '$p | @uri')
                else
                    _enc=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$_winpath")
                fi
                _fname=$(printf '%s' "$_winpath" | tr '\\' '/' | xargs basename)
                _cmd="curl -fsSL ${_auth_flag}'${BASE}/file?path=${_enc}' -o '${_fname}'"

                if [[ "$QUIET" -eq 1 ]]; then
                    printf '%s\n' "$_cmd"
                else
                    echo "  $_winpath"
                    echo "  → $_cmd"
                    echo
                fi
            done
        fi
        ;;
    audio)
        DEST="$(mktemp --suffix=.wav)"
        cp "$TMP_BODY" "$DEST"
        if [[ "$QUIET" -eq 1 ]]; then printf '%s\n' "$DEST"
        else echo "音声を保存しました: $DEST"; fi
        ;;
    url)
        cat "$TMP_BODY"
        [[ "$QUIET" -eq 1 ]] || echo
        ;;
    html)
        cat "$TMP_BODY"
        [[ "$QUIET" -eq 1 ]] || echo
        ;;
    rtf)
        cat "$TMP_BODY"
        [[ "$QUIET" -eq 1 ]] || echo
        ;;
    vfiles)
        if command -v jq &>/dev/null; then
            mapfile -t _vnames < <(jq -r '.[]' < "$TMP_BODY")
        else
            mapfile -t _vnames < <(python3 -c "
import json,sys
for p in json.load(sys.stdin): print(p)" < "$TMP_BODY")
        fi
        if [[ "${#_vnames[@]}" -eq 0 ]]; then
            [[ "$QUIET" -eq 1 ]] || echo "仮想ファイルがありません。"
        else
            _auth_flag=""
            [[ -n "$CLIPD_TOKEN" ]] && _auth_flag="-H 'Authorization: Bearer ${CLIPD_TOKEN}' "
            [[ "$QUIET" -eq 1 ]] || printf 'クリップボード: 仮想ファイル %d件 (Outlook 添付等)\n\n' "${#_vnames[@]}"
            for _i in "${!_vnames[@]}"; do
                _vname="${_vnames[$_i]}"
                _cmd="curl -fsSL ${_auth_flag}'${BASE}/vfile?i=${_i}' -o '${_vname}'"
                if [[ "$QUIET" -eq 1 ]]; then printf '%s\n' "$_cmd"
                else printf '  [%d] %s\n  → %s\n\n' "$_i" "$_vname" "$_cmd"; fi
            done
        fi
        ;;
    empty|"")
        [[ "$QUIET" -eq 1 ]] || echo "クリップボードは空です。"
        ;;
    error)
        echo "clipd error:" >&2; cat "$TMP_BODY" >&2; echo >&2; exit 1
        ;;
    *)
        echo "unknown kind: $KIND" >&2; cat "$TMP_BODY"
        ;;
esac
